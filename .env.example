# ADS-B Receiver Configuration
# Copy this file to .env and fill in your specific values

# General Settings
FEEDER_TZ=Asia/Tokyo
FEEDER_NAME=your-feeder-name
FEEDER_LAT=35.6762
FEEDER_LONG=139.6503
FEEDER_ALT_M=10

# SDR Configuration
READSB_DEVICE_TYPE=rtlsdr
READSB_GAIN=auto
ADSB_SDR_SERIAL=00000001
ADSB_SDR_PPM=0

# Service Keys (obtain from respective services)
FR24_KEY=
PIAWARE_KEY=
AIRNAV_KEY=
PLANEFINDER_KEY=

# Optional: MultiFeeder UUID (leave empty to auto-generate)
MULTIFEEDER_UUID=

# Optional: Terrain/Coverage Analysis
FEEDER_HEYWHATSTHAT_ID=
FEEDER_HEYWHATSTHAT_ALTS=

# Optional: InfluxDB/Prometheus Integration
INFLUX_URL=
INFLUX_TOKEN=
INFLUX_BUCKET=

# Volume Configuration (customize paths if needed)
ADSB_DATA_PATH=/opt/adsb
ULTRAFEEDER_GLOBE_HISTORY_PATH=${ADSB_DATA_PATH}/ultrafeeder/globe_history
ULTRAFEEDER_GRAPHS1090_PATH=${ADSB_DATA_PATH}/ultrafeeder/graphs1090

# Port Configuration (customize if you have conflicts)
ULTRAFEEDER_WEB_PORT=8081
ULTRAFEEDER_STATS_PORT=9273
FR24_WEB_PORT=8754
PIAWARE_WEB_PORT=8080
PIAWARE_BEAST_PORT=30003
PIAWARE_MLAT_PORT=30005
PLANEFINDER_PORT=30053

# Network Configuration
ADSB_NETWORK_NAME=adsb-network
ADSB_NETWORK_SUBNET=172.20.0.0/16

# Restart Policy (unless-stopped, always, on-failure, no)
RESTART_POLICY=unless-stopped

# Logging Configuration
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# Container Log Directory Sizes (tmpfs)
ULTRAFEEDER_LOG_SIZE=32M
FR24_LOG_SIZE=16M
PIAWARE_LOG_SIZE=16M
AIRNAV_LOG_SIZE=8M
PLANEFINDER_LOG_SIZE=8M